<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zcst.manage.mapper.AttendanceStatisticsMapper">
    <resultMap type="com.zcst.manage.domain.AttendanceStatistics" id="AttendanceStatisticsResult">
        <id property="statId" column="stat_id"/>
        <result property="studentId" column="student_id"/>
        <result property="venueId" column="venue_id"/>
        <result property="yearMonth" column="year_month"/>
        <result property="totalDutyHours" column="total_duty_hours"/>
        <result property="checkInCount" column="check_in_count"/>
        <result property="attendanceCount" column="attendance_count"/>
        <result property="absenceCount" column="absence_count"/>
        <result property="lateCount" column="late_count"/>
        <result property="earlyLeaveCount" column="early_leave_count"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="selectAttendanceStatisticsVo">
        select `stat_id`, `student_id`, `venue_id`, `year_month`, `total_duty_hours`, `check_in_count`, `attendance_count`, `absence_count`, `late_count`, `early_leave_count`, `created_at`, `updated_at`
        from attendance_statistics
    </sql>

    <select id="selectAttendanceStatisticsById" parameterType="long" resultMap="AttendanceStatisticsResult">
        <include refid="selectAttendanceStatisticsVo"/>
        where `stat_id` = #{statId}
    </select>

    <select id="selectAttendanceStatisticsList" parameterType="com.zcst.manage.domain.AttendanceStatistics" resultMap="AttendanceStatisticsResult">
        <include refid="selectAttendanceStatisticsVo"/>
        <where>
            <if test="studentId != null and studentId != ''">
                and `student_id` = #{studentId}
            </if>
            <if test="venueId != null">
                and `venue_id` = #{venueId}
            </if>
            <if test="yearMonth != null and yearMonth != ''">
                and `year_month` = #{yearMonth}
            </if>
        </where>
    </select>

    <select id="selectAttendanceStatisticsByStudentIdAndMonth" resultMap="AttendanceStatisticsResult">
        <include refid="selectAttendanceStatisticsVo"/>
        where `student_id` = #{studentId} and `year_month` = #{yearMonth}
    </select>

    <select id="selectAttendanceStatisticsByVenueIdAndMonth" resultMap="AttendanceStatisticsResult">
        <include refid="selectAttendanceStatisticsVo"/>
        where `venue_id` = #{venueId} and `year_month` = #{yearMonth}
    </select>

    <insert id="insertAttendanceStatistics" parameterType="com.zcst.manage.domain.AttendanceStatistics">
        insert into attendance_statistics (`student_id`, `venue_id`, `year_month`, `total_duty_hours`, `check_in_count`, `attendance_count`, `absence_count`, `late_count`, `early_leave_count`)
        values (#{studentId}, #{venueId}, #{yearMonth}, #{totalDutyHours}, #{checkInCount}, #{attendanceCount}, #{absenceCount}, #{lateCount}, #{earlyLeaveCount})
    </insert>

    <update id="updateAttendanceStatistics" parameterType="com.zcst.manage.domain.AttendanceStatistics">
        update attendance_statistics
        set `student_id` = #{studentId},
            `venue_id` = #{venueId},
            `year_month` = #{yearMonth},
            `total_duty_hours` = #{totalDutyHours},
            `check_in_count` = #{checkInCount},
            `attendance_count` = #{attendanceCount},
            `absence_count` = #{absenceCount},
            `late_count` = #{lateCount},
            `early_leave_count` = #{earlyLeaveCount}
        where `stat_id` = #{statId}
    </update>

    <delete id="deleteAttendanceStatisticsById" parameterType="long">
        delete from attendance_statistics
        where `stat_id` = #{statId}
    </delete>

    <delete id="deleteAttendanceStatisticsByIds">
        delete from attendance_statistics
        where `stat_id` in
        <foreach item="statId" collection="array" open="(" separator="," close=")">
            #{statId}
        </foreach>
    </delete>
</mapper>