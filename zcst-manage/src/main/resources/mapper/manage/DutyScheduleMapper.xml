<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zcst.manage.mapper.DutyScheduleMapper">
    <resultMap type="com.zcst.manage.domain.DutySchedule" id="DutyScheduleResult">
        <id property="dutyId" column="duty_id"/>
        <result property="studentId" column="student_id"/>
        <result property="studentName" column="student_name"/>
        <result property="gender" column="gender"/>
        <result property="studentPhone" column="student_phone"/>
        <result property="venueId" column="venue_id"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="selectDutyScheduleVo">
        select ds.duty_id, ds.student_id, s.name as student_name, s.gender, s.phone as student_phone, ds.venue_id, ds.start_time, ds.end_time, ds.remark, ds.created_at, ds.updated_at
        from duty_schedule ds
        left join student s on ds.student_id = s.student_id
    </sql>

    <select id="selectDutyScheduleList" parameterType="com.zcst.manage.domain.DutySchedule" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        <where>
            <if test="studentId != null and studentId != ''">
                and ds.student_id = #{studentId}
            </if>
            <if test="studentName != null and studentName != ''">
                and s.name like concat('%', #{studentName}, '%')
            </if>
            <if test="venueId != null">
                and ds.venue_id = #{venueId}
            </if>
            <if test="startTime != null">
                and ds.start_time >= #{startTime}
            </if>
            <if test="endTime != null">
                and ds.end_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <select id="selectDutyScheduleByStudentId" parameterType="string" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where ds.student_id = #{studentId}
        order by ds.start_time desc
    </select>

    <select id="selectDutyScheduleByVenueId" parameterType="integer" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where ds.venue_id = #{venueId}
        order by ds.start_time desc
    </select>

    <select id="selectDutyScheduleByDutyId" parameterType="integer" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where ds.duty_id = #{dutyId}
    </select>

    <select id="selectOverlappingDuty" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where ds.student_id = #{studentId}
        and ((ds.start_time &lt; #{endTime} and ds.end_time &gt; #{startTime}))
    </select>

    <select id="countVenueDuty" resultType="int">
        select count(*) from duty_schedule
        where venue_id = #{venueId}
        and ((start_time &lt; #{endTime} and end_time &gt; #{startTime}))
    </select>

    <select id="selectStudentsTotalDutyTime" resultType="map">
        select student_id as studentId, sum(TIMESTAMPDIFF(SECOND, start_time, end_time)) as totalTime
        from duty_schedule
        where student_id in
        <foreach item="studentId" collection="studentIds" open="(" separator="," close=")">
            #{studentId}
        </foreach>
        group by student_id
    </select>

    <select id="selectStudentDutyDatesInRange" resultType="map">
        select student_id as studentId, date(start_time) as dutyDate
        from duty_schedule
        where student_id in
        <foreach item="studentId" collection="studentIds" open="(" separator="," close=")">
            #{studentId}
        </foreach>
        and start_time <![CDATA[>=]]> #{startTime}
        and start_time <![CDATA[<=]]> #{endTime}
        group by student_id, date(start_time)
    </select>

    <insert id="insertDutySchedule" parameterType="com.zcst.manage.domain.DutySchedule">
        insert into duty_schedule (student_id, venue_id, start_time, end_time, remark)
        values (#{studentId}, #{venueId}, #{startTime}, #{endTime}, #{remark})
    </insert>

    <update id="updateDutySchedule" parameterType="com.zcst.manage.domain.DutySchedule">
        update duty_schedule
        set student_id = #{studentId},
            venue_id = #{venueId},
            start_time = #{startTime},
            end_time = #{endTime},
            remark = #{remark},
            attendance_status = #{attendanceStatus}
        where duty_id = #{dutyId}
    </update>

    <delete id="deleteDutyScheduleByDutyId" parameterType="integer">
        delete from duty_schedule
        where duty_id = #{dutyId}
    </delete>

    <delete id="deleteDutyScheduleByDutyIds" parameterType="integer">
        delete from duty_schedule
        where duty_id in
        <foreach item="dutyId" collection="array" open="(" separator="," close=")">
            #{dutyId}
        </foreach>
    </delete>

    <delete id="deleteDutyScheduleByVenueAndTime">
        delete from duty_schedule
        where venue_id = #{venueId}
          and time(start_time) = #{startTime}
          and time(end_time) = #{endTime}
    </delete>

    <delete id="deleteDutyScheduleByVenueAndRange">
        delete from duty_schedule
        where venue_id = #{venueId}
          and start_time <![CDATA[>=]]> #{startDate}
          and start_time <![CDATA[<=]]> #{endDate}
    </delete>

    <!-- 查询学生当前可签到的值班信息 -->
    <select id="selectCurrentAvailableDuty" parameterType="map" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where ds.student_id = #{studentId}
          and ds.start_time <![CDATA[<=]]> #{currentTime}
          and ds.end_time <![CDATA[>=]]> #{currentTime}
        order by ds.start_time asc
    </select>
</mapper>
