<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zcst.manage.mapper.DutyScheduleMapper">
    <resultMap type="com.zcst.manage.domain.DutySchedule" id="DutyScheduleResult">
        <id property="dutyId" column="duty_id"/>
        <result property="studentId" column="student_id"/>
        <result property="venueId" column="venue_id"/>
        <result property="startTime" column="start_time"/>
        <result property="endTime" column="end_time"/>
        <result property="remark" column="remark"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="selectDutyScheduleVo">
        select duty_id, student_id, venue_id, start_time, end_time, remark, created_at, updated_at
        from duty_schedule
    </sql>

    <select id="selectDutyScheduleList" parameterType="com.zcst.manage.domain.DutySchedule" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        <where>
            <if test="studentId != null and studentId != ''">
                and student_id = #{studentId}
            </if>
            <if test="venueId != null">
                and venue_id = #{venueId}
            </if>
            <if test="startTime != null">
                and start_time >= #{startTime}
            </if>
            <if test="endTime != null">
                and end_time &lt;= #{endTime}
            </if>
        </where>
    </select>

    <select id="selectDutyScheduleByStudentId" parameterType="string" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where student_id = #{studentId}
        order by start_time desc
    </select>

    <select id="selectDutyScheduleByVenueId" parameterType="integer" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where venue_id = #{venueId}
        order by start_time desc
    </select>

    <select id="selectDutyScheduleByDutyId" parameterType="integer" resultMap="DutyScheduleResult">
        <include refid="selectDutyScheduleVo"/>
        where duty_id = #{dutyId}
    </select>

    <insert id="insertDutySchedule" parameterType="com.zcst.manage.domain.DutySchedule">
        insert into duty_schedule (student_id, venue_id, start_time, end_time, remark)
        values (#{studentId}, #{venueId}, #{startTime}, #{endTime}, #{remark})
    </insert>

    <update id="updateDutySchedule" parameterType="com.zcst.manage.domain.DutySchedule">
        update duty_schedule
        set student_id = #{studentId},
            venue_id = #{venueId},
            start_time = #{startTime},
            end_time = #{endTime},
            remark = #{remark}
        where duty_id = #{dutyId}
    </update>

    <delete id="deleteDutyScheduleByDutyId" parameterType="integer">
        delete from duty_schedule
        where duty_id = #{dutyId}
    </delete>

    <delete id="deleteDutyScheduleByDutyIds" parameterType="integer">
        delete from duty_schedule
        where duty_id in
        <foreach item="dutyId" collection="array" open="(" separator="," close=")">
            #{dutyId}
        </foreach>
    </delete>
</mapper>