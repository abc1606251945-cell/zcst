<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zcst.manage.mapper.MajorMapper">

    <resultMap type="com.zcst.manage.domain.Major" id="MajorResult">
        <id property="majorId" column="major_id"/>
        <result property="majorName" column="major_name"/>
        <result property="collegeId" column="college_id"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <select id="selectMajorList" resultMap="MajorResult">
        select major_id, major_name, college_id, created_at, updated_at
        from major
        order by major_id asc
    </select>

</mapper>
