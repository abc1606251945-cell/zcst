<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zcst.manage.mapper.VenueMapper">
    
    <resultMap type="Venue" id="VenueResult">
        <result property="venueId"    column="venue_id"    />
        <result property="venueName"    column="venue_name"    />
        <result property="createdAt"    column="created_at"    />
        <result property="updatedAt"    column="updated_at"    />
    </resultMap>

    <sql id="selectVenueVo">
        select venue_id, venue_name, created_at, updated_at from venue
    </sql>

    <select id="selectVenueList" parameterType="Venue" resultMap="VenueResult">
        <include refid="selectVenueVo"/>
        <where>  
            <if test="venueName != null  and venueName != ''"> and venue_name like concat('%', #{venueName}, '%')</if>
            <if test="createdAt != null "> and created_at = #{createdAt}</if>
            <if test="updatedAt != null "> and updated_at = #{updatedAt}</if>
        </where>
    </select>
    
    <select id="selectVenueByVenueId" parameterType="Long" resultMap="VenueResult">
        <include refid="selectVenueVo"/>
        where venue_id = #{venueId}
    </select>

    <insert id="insertVenue" parameterType="Venue" useGeneratedKeys="true" keyProperty="venueId">
        insert into venue
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="venueName != null and venueName != ''">venue_name,</if>
            <if test="createdAt != null">created_at,</if>
            <if test="updatedAt != null">updated_at,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="venueName != null and venueName != ''">#{venueName},</if>
            <if test="createdAt != null">#{createdAt},</if>
            <if test="updatedAt != null">#{updatedAt},</if>
         </trim>
    </insert>

    <update id="updateVenue" parameterType="Venue">
        update venue
        <trim prefix="SET" suffixOverrides=",">
            <if test="venueName != null and venueName != ''">venue_name = #{venueName},</if>
            <if test="createdAt != null">created_at = #{createdAt},</if>
            <if test="updatedAt != null">updated_at = #{updatedAt},</if>
        </trim>
        where venue_id = #{venueId}
    </update>

    <delete id="deleteVenueByVenueId" parameterType="Long">
        delete from venue where venue_id = #{venueId}
    </delete>

    <delete id="deleteVenueByVenueIds" parameterType="String">
        delete from venue where venue_id in 
        <foreach item="venueId" collection="array" open="(" separator="," close=")">
            #{venueId}
        </foreach>
    </delete>
</mapper>